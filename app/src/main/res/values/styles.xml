<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App style để tránh lỗi AAPT khi dùng App.* -->
    <style name="App" parent="" />

    <!-- ═══════════════════════════════════════════
         TYPOGRAPHY STYLES
         ═══════════════════════════════════════════ -->

    <style name="App.Text" parent="android:Widget.TextView">
        <item name="android:textColor">@color/mauChuChinh</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="App.Text.DisplayLg">
        <item name="android:textSize">@dimen/text_display_lg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="App.Text.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="App.Text.DisplaySm">
        <item name="android:textSize">@dimen/text_display_sm</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.HeadingLg">
        <item name="android:textSize">@dimen/text_heading_lg</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.Heading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.Subtitle">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/mauChuPhu</item>
    </style>

    <style name="App.Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="App.Text.BodyLg">
        <item name="android:textSize">@dimen/text_body_lg</item>
    </style>

    <style name="App.Text.BodySm">
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:textColor">@color/mauChuPhu</item>
    </style>

    <style name="App.Text.Small">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textColor">@color/mauChuPhu</item>
    </style>

    <style name="App.Text.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/mauChuMo</item>
    </style>

    <style name="App.Text.Price">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mauCamChinh</item>
    </style>

    <style name="App.Text.PriceLg">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mauCamChinh</item>
    </style>

    <!-- Text trên gradient (trắng) -->
    <style name="App.Text.OnGradient">
        <item name="android:textColor">@color/mauChuTrenGradient</item>
    </style>

    <style name="App.Text.OnGradient.Heading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.OnGradient.DisplaySm">
        <item name="android:textSize">@dimen/text_display_sm</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.OnGradient.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/mauChuTrenGradientPhu</item>
    </style>

    <style name="App.Text.OnGradient.Subtitle">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.Label">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textColor">@color/mauChuMo</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="App.Text.SectionTitle">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mauChuChinh</item>
        <item name="android:paddingStart">@dimen/space_xs</item>
        <item name="android:paddingEnd">@dimen/space_xs</item>
    </style>

    <!-- ═══════════════════════════════════════════
         BUTTON STYLES
         ═══════════════════════════════════════════ -->

    <style name="App.Button" parent="android:Widget.Material.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/space_xxl</item>
        <item name="android:paddingEnd">@dimen/space_xxl</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="App.Button.Primary">
        <item name="android:background">@drawable/bg_nut_chinh_selector</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:elevation">@dimen/elevation_md</item>
    </style>

    <style name="App.Button.Secondary">
        <item name="android:background">@drawable/bg_nut_phu</item>
        <item name="android:textColor">@color/mauTimChinh</item>
    </style>

    <style name="App.Button.Outline">
        <item name="android:background">@drawable/bg_nut_outline_selector</item>
        <item name="android:textColor">@color/mauTimChinh</item>
    </style>

    <style name="App.Button.Ghost">
        <item name="android:background">@drawable/bg_nut_ghost</item>
        <item name="android:textColor">@color/mauTimChinh</item>
        <item name="android:minHeight">@dimen/btn_height_sm</item>
    </style>

    <style name="App.Button.Accent">
        <item name="android:background">@drawable/bg_nut_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:elevation">@dimen/elevation_md</item>
    </style>

    <style name="App.Button.Danger">
        <item name="android:background">@drawable/bg_nut_ghost</item>
        <item name="android:textColor">@color/mauNguyHiem</item>
        <item name="android:minHeight">@dimen/btn_height_sm</item>
    </style>

    <style name="App.Button.Small">
        <item name="android:background">@drawable/bg_nut_chinh_selector</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">@dimen/btn_height_sm</item>
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:paddingStart">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/space_lg</item>
    </style>

    <style name="App.Button.OnGradient">
        <item name="android:background">@drawable/bg_nut_sang</item>
        <item name="android:textColor">@color/mauTimDam</item>
        <item name="android:minHeight">@dimen/btn_height_sm</item>
        <item name="android:textSize">@dimen/text_body_sm</item>
    </style>

    <style name="App.Button.Counter" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/bg_nut_so_luong</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minEms">0</item>
        <item name="android:padding">0dp</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textAlignment">center</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="App.Button.Tab">
        <item name="android:background">@drawable/bg_bottom_nav_item</item>
        <item name="android:textColor">@color/mauTimDam</item>
        <item name="android:minHeight">@dimen/tab_height</item>
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/space_lg</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="App.Button.TabActive">
        <item name="android:background">@drawable/bg_bottom_nav_active</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">@dimen/tab_height</item>
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/space_lg</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="App.Button.DrawerItem">
        <item name="android:background">@drawable/bg_drawer_item</item>
        <item name="android:textColor">@color/mauChuTrenGradientPhu</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/space_lg</item>
        <item name="android:drawablePadding">@dimen/space_md</item>
        <item name="android:drawableTint">@color/mauChuTrenGradientPhu</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="App.Button.DrawerItemActive">
        <item name="android:background">@drawable/bg_drawer_item_active</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/space_lg</item>
        <item name="android:drawablePadding">@dimen/space_md</item>
        <item name="android:drawableTint">@color/white</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Nút icon tròn trên nền gradient (menu, quay lại) -->
    <style name="App.IconButton.OnGradient" parent="">
        <item name="android:background">@drawable/bg_nut_icon_tren_gradient</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:padding">@dimen/space_md</item>
        <item name="android:tint">@color/white</item>
    </style>

    <!-- Nút gửi tròn (chat) -->
    <style name="App.IconButton.Send" parent="">
        <item name="android:background">@drawable/bg_nut_gui</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:padding">@dimen/space_md</item>
        <item name="android:tint">@color/white</item>
    </style>

    <!-- ═══════════════════════════════════════════
         CARD STYLES
         ═══════════════════════════════════════════ -->

    <style name="App.Card">
        <item name="android:background">@drawable/bg_card_modern</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <style name="App.Card.Elevated">
        <item name="android:elevation">@dimen/elevation_lg</item>
    </style>

    <style name="App.Card.Glass">
        <item name="android:background">@drawable/bg_card_glass</item>
        <item name="android:elevation">@dimen/elevation_md</item>
    </style>

    <!-- ═══════════════════════════════════════════
         INPUT STYLES
         ═══════════════════════════════════════════ -->

    <style name="App.Input" parent="android:Widget.Material.EditText">
        <item name="android:background">@drawable/bg_o_nhap</item>
        <item name="android:textColor">@color/mauChuChinh</item>
        <item name="android:textColorHint">@color/mauChuMo</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:minHeight">@dimen/input_height</item>
        <item name="android:paddingStart">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/space_lg</item>
        <item name="android:paddingTop">@dimen/space_md</item>
        <item name="android:paddingBottom">@dimen/space_md</item>
    </style>

    <!-- ═══════════════════════════════════════════
         BADGE STYLES
         ═══════════════════════════════════════════ -->

    <style name="App.Badge">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">@dimen/space_md</item>
        <item name="android:paddingEnd">@dimen/space_md</item>
        <item name="android:paddingTop">@dimen/space_xs</item>
        <item name="android:paddingBottom">@dimen/space_xs</item>
    </style>

    <style name="App.Badge.Success">
        <item name="android:background">@drawable/bg_badge_success</item>
        <item name="android:textColor">@color/mauThanhCong</item>
    </style>

    <style name="App.Badge.Warning">
        <item name="android:background">@drawable/bg_badge_warning</item>
        <item name="android:textColor">@color/mauCamDam</item>
    </style>

    <style name="App.Badge.Info">
        <item name="android:background">@drawable/bg_badge_info</item>
        <item name="android:textColor">@color/mauXanhDuong</item>
    </style>

    <style name="App.Badge.Purple">
        <item name="android:background">@drawable/bg_badge_tim</item>
        <item name="android:textColor">@color/mauTimDam</item>
    </style>

    <!-- ═══════════════════════════════════════════
         EMPTY STATE
         ═══════════════════════════════════════════ -->

    <style name="App.EmptyState">
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/mauChuMo</item>
        <item name="android:padding">@dimen/space_xxxl</item>
        <item name="android:drawablePadding">@dimen/space_lg</item>
    </style>

    <!-- ═══════════════════════════════════════════
         COUNTER TEXT (Số lượng +/-)
         ═══════════════════════════════════════════ -->

    <style name="App.Text.Counter">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mauChuChinh</item>
        <item name="android:gravity">center</item>
    </style>

</resources>
