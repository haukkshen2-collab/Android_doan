<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Quan_Ly_Ban_Ve" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/mauNenChinh</item>
        <item name="colorPrimary">@color/mauTimChinh</item>
        <item name="colorPrimaryVariant">@color/mauTimDam</item>
        <item name="android:colorAccent">@color/mauCamChinh</item>
        <item name="android:textColorPrimary">@color/mauChuChinh</item>
        <item name="android:textColorSecondary">@color/mauChuPhu</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:buttonStyle">@style/App.Button.Primary</item>
        <item name="android:editTextStyle">@style/App.Input</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.Quan_Ly_Ban_Ve" parent="Base.Theme.Quan_Ly_Ban_Ve" />

    <!-- Dialog theme Material 3, bo góc lớn -->
    <style name="App.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowBackground">@drawable/bg_card_modern</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorPrimary">@color/mauTimChinh</item>
        <item name="android:textColorPrimary">@color/mauChuChinh</item>
        <item name="android:textColorSecondary">@color/mauChuPhu</item>
    </style>

</resources>
