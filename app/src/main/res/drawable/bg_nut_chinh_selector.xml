<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/mauNutTat" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="@color/mauTimDam"
                android:endColor="@color/mauCamDam"
                android:type="linear" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="@color/gradientTimCamBatDau"
                android:endColor="@color/gradientTimCamKetThuc"
                android:type="linear" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
</selector>
