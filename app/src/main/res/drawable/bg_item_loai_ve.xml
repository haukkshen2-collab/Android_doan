<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="@color/mauTimChinh"
                android:endColor="@color/mauTimTrung"
                android:type="linear" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/mauTimNhat" />
            <corners android:radius="@dimen/radius_pill" />
            <stroke
                android:width="@dimen/border_thin"
                android:color="@color/mauTimChinh" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/mauNenCard" />
            <corners android:radius="@dimen/radius_pill" />
            <stroke
                android:width="@dimen/border_thin"
                android:color="@color/mauVien" />
        </shape>
    </item>
</selector>
