<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="@color/mauCamDam"
                android:endColor="@color/mauVangDam"
                android:type="linear" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="@color/gradientCamBatDau"
                android:endColor="@color/gradientCamKetThuc"
                android:type="linear" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
</selector>
