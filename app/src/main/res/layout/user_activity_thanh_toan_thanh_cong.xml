<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding_lg">

        <TextView
            style="@style/App.Text.Display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Thanh toán thành công" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xxl"
            android:background="@drawable/bg_card_modern"
            android:elevation="@dimen/elevation_md"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_lg">

            <TextView
                style="@style/App.Text.PriceLg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Đặt vé thành công" />

            <TextView
                android:id="@+id/lblMaHoaDon"
                style="@style/App.Text.BodyLg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:gravity="center"
                android:text="Mã hóa đơn:" />

            <TextView
                android:id="@+id/lblNoiDungChuyenKhoan"
                style="@style/App.Text.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:text="Thanh toán đã được xác nhận." />
        </LinearLayout>

        <Button
            android:id="@+id/btnVeTrangChu"
            style="@style/App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/space_xxl"
            android:text="Về trang chủ" />
    </LinearLayout>
</ScrollView>
