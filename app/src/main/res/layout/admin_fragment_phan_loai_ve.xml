<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/lblTieuDe"
            android:drawableStart="@drawable/ic_loai_ve"
            android:drawablePadding="@dimen/space_sm"
            android:drawableTint="@color/mauTimChinh"
            android:gravity="center_vertical"
            style="@style/App.Text.HeadingLg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Phân loại vé" />

        <Button
            android:id="@+id/btnBoLoc"
            android:drawableStart="@drawable/ic_loc"
            android:drawablePadding="@dimen/space_xs"
            android:drawableTint="@color/mauTimChinh"
            style="@style/App.Button.Outline"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/btn_height_sm"
            android:minWidth="@dimen/btn_height"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:text="Lọc" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layBoLoc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@drawable/bg_card_modern"
        android:orientation="vertical"
        android:padding="@dimen/card_padding"
        android:visibility="gone">

        <EditText
            android:id="@+id/edtTimKiem"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tìm theo tên hoặc mô tả"
            android:inputType="text"
            android:singleLine="true" />
    </LinearLayout>

    <Button
        android:id="@+id/btnThemLoaiVe"
        android:drawableStart="@drawable/ic_them"
        android:drawablePadding="@dimen/space_xs"
        android:drawableTint="@color/white"
        style="@style/App.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginTop="@dimen/space_sm"
        android:text="Thêm loại vé" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvDanhSachLoaiVe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_weight="1"
        android:clipToPadding="false" />
</LinearLayout>
