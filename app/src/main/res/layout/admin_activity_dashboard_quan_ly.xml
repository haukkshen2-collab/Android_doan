<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh">

    <LinearLayout
        android:id="@+id/layNoiDungChinh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ═══ Toolbar admin ═══ -->
        <LinearLayout
            android:id="@+id/layToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mauTimChinh"
            android:elevation="@dimen/elevation_md"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md">

            <ImageButton
                android:id="@+id/btnMoMenu"
                style="@style/App.IconButton.OnGradient"
                android:layout_width="@dimen/btn_height_sm"
                android:layout_height="@dimen/btn_height_sm"
                android:contentDescription="Mở menu quản lý"
                android:src="@drawable/ic_menu" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/lblXinChaoAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Xin chào quản lý"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lblManHinhDangChon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xxs"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Đang xem: Tổng quan"
                    android:textColor="@color/mauChuTrenGradientPhu"
                    android:textSize="@dimen/text_body_sm" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Content ═══ -->
        <FrameLayout
            android:id="@+id/layNoiDungQuanLy"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- ═══ Drawer phủ từ mép trái ═══ -->
    <FrameLayout
        android:id="@+id/layMenuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/mauOverlayNhe"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layMenuQuanLy"
            android:layout_width="@dimen/drawer_width"
            android:layout_height="match_parent"
            android:background="@color/mauChuChinh"
            android:clickable="true"
            android:elevation="@dimen/elevation_xl"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_xl"
            android:paddingEnd="@dimen/space_md">

            <!-- Header drawer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_sm"
                android:paddingBottom="@dimen/space_lg">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_logo_tron"
                    android:contentDescription="Logo khu du lịch"
                    android:padding="@dimen/space_sm"
                    android:src="@drawable/img_vaa_e1744105217584" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bảng điều khiển"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_subtitle"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Khu du lịch"
                        android:textColor="@color/mauChuTrenGradientPhu"
                        android:textSize="@dimen/text_small" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnTongQuan"
                style="@style/App.Button.DrawerItemActive"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:drawableStart="@drawable/ic_thong_ke"
                android:text="Tổng quan" />

            <Button
                android:id="@+id/btnQuanLyVe"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:drawableStart="@drawable/ic_ve"
                android:text="Quản lý vé" />

            <Button
                android:id="@+id/btnLoaiVe"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:drawableStart="@drawable/ic_loai_ve"
                android:text="Loại vé" />

            <Button
                android:id="@+id/btnVoucher"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:drawableStart="@drawable/ic_voucher"
                android:text="Voucher" />

            <Button
                android:id="@+id/btnNguoiDung"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:drawableStart="@drawable/ic_nhom"
                android:text="Người dùng" />

            <Button
                android:id="@+id/btnHoaDon"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:drawableStart="@drawable/ic_hoa_don"
                android:text="Hóa đơn" />

            <Button
                android:id="@+id/btnCauHinhAI"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:drawableStart="@drawable/ic_ai"
                android:text="Cấu hình AI" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnDangXuat"
                style="@style/App.Button.DrawerItem"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_xl"
                android:drawableStart="@drawable/ic_dang_xuat"
                android:drawableTint="@color/mauNguyHiem"
                android:text="Đăng xuất"
                android:textColor="@color/mauNguyHiem" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
