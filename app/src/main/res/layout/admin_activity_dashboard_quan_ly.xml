<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical">

    <!-- ═══ Hero Header Admin ═══ -->
    <LinearLayout
        android:id="@+id/layToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mauTimChinh"
        android:elevation="@dimen/elevation_md"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lblXinChaoAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Xin chào quản lý"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Bảng điều khiển"
                android:textColor="#E0E0E0"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDangXuat"
            style="@style/App.Button.OnGradient"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Đăng xuất"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ═══ Tab Menu ═══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:fillViewport="false"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layMenuQuanLy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_sm">

            <Button
                android:id="@+id/btnTongQuan"
                style="@style/App.Button.TabActive"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:text="📊 Tổng quan" />

            <Button
                android:id="@+id/btnQuanLyVe"
                style="@style/App.Button.Tab"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:layout_marginStart="@dimen/space_sm"
                android:text="🎫 Quản lý vé" />

            <Button
                android:id="@+id/btnLoaiVe"
                style="@style/App.Button.Tab"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:layout_marginStart="@dimen/space_sm"
                android:text="📂 Loại vé" />

            <Button
                android:id="@+id/btnVoucher"
                style="@style/App.Button.Tab"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:layout_marginStart="@dimen/space_sm"
                android:text="🎁 Voucher" />

            <Button
                android:id="@+id/btnNguoiDung"
                style="@style/App.Button.Tab"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:layout_marginStart="@dimen/space_sm"
                android:text="👥 Người dùng" />

            <Button
                android:id="@+id/btnHoaDon"
                style="@style/App.Button.Tab"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:layout_marginStart="@dimen/space_sm"
                android:text="🧾 Hóa đơn" />

            <Button
                android:id="@+id/btnCauHinhAI"
                style="@style/App.Button.Tab"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/tab_height"
                android:layout_marginStart="@dimen/space_sm"
                android:text="🤖 Cấu hình AI" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ═══ Content ═══ -->
    <FrameLayout
        android:id="@+id/layNoiDungQuanLy"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
