<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <!-- ═══ Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_user"
        android:elevation="@dimen/elevation_lg"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:id="@+id/lblTieuDe"
            android:drawableStart="@drawable/ic_lich_su"
            android:drawablePadding="@dimen/space_sm"
            android:drawableTint="@color/white"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lịch sử đơn hàng"
            style="@style/App.Text.OnGradient.DisplaySm" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="Xem lại các đơn hàng đã thanh toán"
            style="@style/App.Text.OnGradient.Body" />
    </LinearLayout>

    <!-- ═══ Empty state ═══ -->
    <TextView
        android:id="@+id/lblTrong"
        android:drawableTop="@drawable/ic_trong"
        android:drawableTint="@color/mauChuMo"
        style="@style/App.EmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xxl"
        android:background="@drawable/bg_card_modern"
        android:text="Chưa có đơn hàng đã thanh toán"
        android:visibility="gone" />

    <!-- ═══ Danh sách ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvLichSuDonHang"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_sm" />
</LinearLayout>
