<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- ═══ Hero gradient phía trên ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_user"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_xxxl"
            android:paddingTop="@dimen/space_huge"
            android:paddingEnd="@dimen/space_xxxl"
            android:paddingBottom="@dimen/space_huge">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="@dimen/logo_size_lg"
                android:layout_height="@dimen/logo_size_lg"
                android:background="@drawable/bg_logo_tron"
                android:contentDescription="Logo"
                android:padding="@dimen/space_lg"
                android:src="@drawable/img_vaa_e1744105217584" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="Khu Du Lịch"
                style="@style/App.Text.OnGradient.DisplaySm" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="Đặt vé trực tuyến"
                style="@style/App.Text.OnGradient.Body" />
        </LinearLayout>

        <!-- ═══ Form card glassmorphism ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xl"
            android:layout_marginTop="-32dp"
            android:layout_marginEnd="@dimen/space_xl"
            android:layout_marginBottom="@dimen/space_xl"
            android:background="@drawable/bg_card_modern"
            android:elevation="@dimen/elevation_lg"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/space_xxl">

            <TextView
                android:id="@+id/lblTieuDe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Chào mừng trở lại"
                style="@style/App.Text.DisplaySm" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:text="Đăng nhập để tiếp tục đặt vé"
                style="@style/App.Text.BodySm" />

            <EditText
                android:id="@+id/edtTaiKhoan"
                style="@style/App.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xxl"
                android:hint="Tài khoản"
                android:inputType="text"
                android:imeOptions="actionNext" />

            <EditText
                android:id="@+id/edtMatKhau"
                style="@style/App.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:hint="Mật khẩu"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />

            <CheckBox
                android:id="@+id/chkGhiNhoMatKhau"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:minHeight="@dimen/btn_height_sm"
                android:text="Ghi nhớ đăng nhập"
                android:textColor="@color/mauChuPhu"
                android:textSize="@dimen/text_body"
                android:buttonTint="@color/mauTimChinh" />

            <ProgressBar
                android:id="@+id/pgbDangTai"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:indeterminateTint="@color/mauTimChinh"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnDangNhap"
                style="@style/App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_lg"
                android:text="Đăng nhập" />

            <Button
                android:id="@+id/btnDangKy"
                style="@style/App.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Tạo tài khoản mới" />

            <TextView
                android:id="@+id/lblQuenMatKhau"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:minHeight="@dimen/btn_height_sm"
                android:gravity="center"
                android:foreground="?attr/selectableItemBackground"
                android:text="Quên mật khẩu?"
                android:textColor="@color/mauTimChinh"
                android:textSize="@dimen/text_body" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
