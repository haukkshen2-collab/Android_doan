<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:id="@+id/lblTieuDe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎁 Quản lý voucher"
        style="@style/App.Text.HeadingLg" />

    <Button
        android:id="@+id/btnThemVoucher"
        style="@style/App.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginTop="@dimen/space_md"
        android:text="➕ Thêm voucher" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvDanhSachVoucher"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_weight="1"
        android:clipToPadding="false" />
</LinearLayout>
