<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_modern"
        android:orientation="vertical"
        android:padding="@dimen/space_xxl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="🎁 Thêm / Sửa voucher"
            style="@style/App.Text.HeadingLg" />

        <EditText
            android:id="@+id/edtMaGiamGia"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:hint="Mã giảm giá"
            android:inputType="textCapCharacters" />

        <EditText
            android:id="@+id/edtTenVoucher"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:hint="Tên voucher"
            android:inputType="text" />

        <RadioGroup
            android:id="@+id/rgKieuGiamGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_card_gradient"
            android:orientation="horizontal"
            android:padding="@dimen/space_md">

            <RadioButton
                android:id="@+id/radPhanTram"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:minHeight="@dimen/btn_height_sm"
                android:text="Phần trăm"
                android:textSize="@dimen/text_body"
                android:buttonTint="@color/mauTimChinh" />

            <RadioButton
                android:id="@+id/radTienMat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="@dimen/btn_height_sm"
                android:text="Tiền mặt"
                android:textSize="@dimen/text_body"
                android:buttonTint="@color/mauTimChinh" />
        </RadioGroup>

        <EditText
            android:id="@+id/edtGiaTriGiam"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:hint="Giá trị giảm"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/edtNgayBatDau"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:clickable="true"
            android:focusable="false"
            android:hint="📅 Ngày bắt đầu"
            android:inputType="none" />

        <EditText
            android:id="@+id/edtNgayKetThuc"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:clickable="true"
            android:focusable="false"
            android:hint="📅 Ngày kết thúc"
            android:inputType="none" />

        <EditText
            android:id="@+id/edtSoLuong"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:hint="Số lượng"
            android:inputType="number" />

        <Switch
            android:id="@+id/swtTrangThai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:checked="true"
            android:minHeight="@dimen/btn_height_sm"
            android:text="Đang hoạt động"
            android:textColor="@color/mauChuPhu"
            android:textSize="@dimen/text_body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnHuy"
                style="@style/App.Button.Outline"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_marginEnd="@dimen/space_sm"
                android:layout_weight="1"
                android:text="Hủy" />

            <Button
                android:id="@+id/btnLuu"
                style="@style/App.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_weight="1"
                android:text="💾 Lưu" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
