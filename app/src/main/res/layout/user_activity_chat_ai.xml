<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical">

    <!-- ═══ Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_user"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingTop="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:paddingBottom="@dimen/space_lg">

        <ImageView
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl"
            android:background="@drawable/bg_icon_tron_trang_mo"
            android:contentDescription="Trợ lý ảo"
            android:padding="@dimen/space_md"
            android:src="@drawable/ic_ai"
            android:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lblTieuDe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trợ lý ảo"
                style="@style/App.Text.OnGradient.Heading" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xxs"
                android:text="Hỏi đáp về vé, giá và voucher"
                style="@style/App.Text.OnGradient.Body" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ Danh sách tin nhắn ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvLichSuChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/space_md" />

    <!-- ═══ Đang trả lời ═══ -->
    <ProgressBar
        android:id="@+id/pgbDangTra"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_sm"
        android:indeterminateTint="@color/mauTimChinh"
        android:visibility="gone" />

    <!-- ═══ Thanh nhập tin nhắn ═══ -->
    <LinearLayout
        android:id="@+id/layNhap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_thanh_menu"
        android:elevation="@dimen/elevation_lg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <EditText
            android:id="@+id/edtCauHoi"
            style="@style/App.Input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nhập câu hỏi về vé, giá hoặc voucher..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:imeOptions="actionSend" />

        <ImageButton
            android:id="@+id/btnGui"
            style="@style/App.IconButton.Send"
            android:layout_width="@dimen/btn_height"
            android:layout_height="@dimen/btn_height"
            android:layout_marginStart="@dimen/space_sm"
            android:contentDescription="Gửi câu hỏi"
            android:src="@drawable/ic_gui" />
    </LinearLayout>
</LinearLayout>
