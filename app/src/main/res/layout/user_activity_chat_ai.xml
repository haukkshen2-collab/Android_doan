<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical">

    <!-- ═══ Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_user"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_xl"
        android:paddingTop="@dimen/space_xxl"
        android:paddingEnd="@dimen/space_xl"
        android:paddingBottom="@dimen/space_xl">

        <TextView
            android:id="@+id/lblTieuDe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 Trợ lý ảo"
            style="@style/App.Text.OnGradient.DisplaySm" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="Hỏi đáp về vé và dịch vụ"
            style="@style/App.Text.OnGradient.Body" />
    </LinearLayout>

    <!-- ═══ Chat list ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvLichSuChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/space_md" />

    <!-- ═══ Đang trả lời ═══ -->
    <ProgressBar
        android:id="@+id/pgbDangTra"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_sm"
        android:indeterminateTint="@color/mauTimChinh"
        android:visibility="gone" />

    <!-- ═══ Input bar ═══ -->
    <LinearLayout
        android:id="@+id/layNhap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_modern"
        android:elevation="@dimen/elevation_lg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <EditText
            android:id="@+id/edtCauHoi"
            style="@style/App.Input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nhập câu hỏi..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:imeOptions="actionSend" />

        <Button
            android:id="@+id/btnGui"
            style="@style/App.Button.Small"
            android:layout_width="@dimen/btn_height"
            android:layout_height="@dimen/btn_height"
            android:layout_marginStart="@dimen/space_sm"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="➤" />
    </LinearLayout>
</LinearLayout>
