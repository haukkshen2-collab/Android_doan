<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_sm"
    android:layout_marginTop="@dimen/space_sm"
    android:layout_marginEnd="@dimen/space_sm"
    android:background="@drawable/bg_card_accent"
    android:elevation="@dimen/elevation_md"
    android:foreground="@drawable/bg_ripple_bounded"
    android:orientation="vertical"
    android:padding="@dimen/card_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/lblMaGiamGia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mã giảm giá"
            style="@style/App.Text.Title" />

        <TextView
            android:id="@+id/lblTrangThai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_success"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_xxs"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_xxs"
            android:text="Trạng thái:"
            android:textColor="@color/mauThanhCong"
            android:textSize="@dimen/text_small"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/lblTenVoucher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:text="Tên voucher"
        style="@style/App.Text.Body" />

    <TextView
        android:id="@+id/lblGiaTri"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:text="Giá trị:"
        style="@style/App.Text.Price" />

    <TextView
        android:id="@+id/lblThoiHan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:text="Thời hạn:"
        style="@style/App.Text.BodySm" />

    <TextView
        android:id="@+id/lblSoLuong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xxs"
        android:text="Số lượng:"
        style="@style/App.Text.BodySm" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSua"
            android:drawableStart="@drawable/ic_sua"
            android:drawablePadding="@dimen/space_xs"
            android:drawableTint="@color/mauTimChinh"
            style="@style/App.Button.Outline"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height_sm"
            android:layout_marginEnd="@dimen/space_sm"
            android:layout_weight="1"
            android:text="Sửa" />

        <Button
            android:id="@+id/btnXoa"
            android:drawableStart="@drawable/ic_xoa"
            android:drawablePadding="@dimen/space_xs"
            android:drawableTint="@color/mauNguyHiem"
            style="@style/App.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height_sm"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:text="Xóa" />
    </LinearLayout>
</LinearLayout>
