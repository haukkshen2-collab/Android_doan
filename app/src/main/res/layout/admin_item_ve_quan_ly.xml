<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_sm"
    android:layout_marginTop="@dimen/space_sm"
    android:layout_marginEnd="@dimen/space_sm"
    android:layout_marginBottom="@dimen/space_sm"
    android:background="@drawable/bg_card_modern"
    android:elevation="@dimen/elevation_md"
    android:foreground="@drawable/bg_ripple_bounded"
    android:orientation="vertical"
    android:padding="@dimen/space_md">

    <!-- ═══ Ảnh vé ═══ -->
    <ImageView
        android:id="@+id/imgAnhVe"
        android:layout_width="match_parent"
        android:layout_height="@dimen/img_card_height"
        android:contentDescription="Ảnh vé"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/lblTenVe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Tên vé"
        style="@style/App.Text.Title" />

    <TextView
        android:id="@+id/lblLoaiVe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:background="@drawable/bg_badge_tim"
        android:paddingStart="@dimen/space_md"
        android:paddingTop="@dimen/space_xxs"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_xxs"
        android:text="Loại vé:"
        android:textColor="@color/mauTimDam"
        android:textSize="@dimen/text_small" />

    <TextView
        android:id="@+id/lblGiaVe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:text="Giá vé: 0 VNĐ"
        style="@style/App.Text.Price" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/lblSoLuong"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Số lượng: 0"
            style="@style/App.Text.BodySm" />

        <TextView
            android:id="@+id/lblTrangThai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái:"
            style="@style/App.Text.BodySm" />
    </LinearLayout>

    <!-- ═══ Action buttons ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSua"
            style="@style/App.Button.Outline"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height_sm"
            android:layout_marginEnd="@dimen/space_sm"
            android:layout_weight="1"
            android:text="✏️ Sửa" />

        <Button
            android:id="@+id/btnXoa"
            style="@style/App.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height_sm"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:text="🗑️ Xóa" />
    </LinearLayout>
</LinearLayout>
