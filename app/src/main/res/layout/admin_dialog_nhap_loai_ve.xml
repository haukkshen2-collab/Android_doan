<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_modern"
    android:orientation="vertical"
    android:padding="@dimen/space_xxl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="📂 Thêm / Sửa loại vé"
        style="@style/App.Text.HeadingLg" />

    <EditText
        android:id="@+id/edtTenLoaiVe"
        style="@style/App.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xl"
        android:hint="Tên loại vé"
        android:inputType="text" />

    <EditText
        android:id="@+id/edtMoTa"
        style="@style/App.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:hint="Mô tả"
        android:inputType="textMultiLine"
        android:minLines="3" />

    <Switch
        android:id="@+id/swtTrangThai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:checked="true"
        android:minHeight="@dimen/btn_height_sm"
        android:text="Đang hoạt động"
        android:textColor="@color/mauChuPhu"
        android:textSize="@dimen/text_body" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xl"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnHuy"
            style="@style/App.Button.Outline"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_marginEnd="@dimen/space_sm"
            android:layout_weight="1"
            android:text="Hủy" />

        <Button
            android:id="@+id/btnLuu"
            style="@style/App.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:text="💾 Lưu" />
    </LinearLayout>
</LinearLayout>
