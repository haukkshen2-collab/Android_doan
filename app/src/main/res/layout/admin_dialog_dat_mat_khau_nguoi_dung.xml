<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_modern"
    android:orientation="vertical"
    android:padding="@dimen/space_xxl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Đặt lại mật khẩu"
        style="@style/App.Text.HeadingLg" />

    <TextView
        android:id="@+id/lblTaiKhoan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:background="@drawable/bg_card_gradient"
        android:padding="@dimen/space_md"
        android:text="Tài khoản"
        style="@style/App.Text.Title" />

    <EditText
        android:id="@+id/edtMatKhauMoi"
        style="@style/App.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:hint="Nhập mật khẩu mới"
        android:inputType="textPassword" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xl"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnHuy"
            style="@style/App.Button.Outline"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_marginEnd="@dimen/space_sm"
            android:layout_weight="1"
            android:text="Hủy" />

        <Button
            android:id="@+id/btnLuu"
            android:drawableStart="@drawable/ic_luu"
            android:drawablePadding="@dimen/space_xs"
            android:drawableTint="@color/white"
            style="@style/App.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:text="Lưu" />
    </LinearLayout>
</LinearLayout>
