<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/lblTieuDe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cấu hình AI Gemini"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtNhaCungCap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="URL endpoint Gemini"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/edtKhoaApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Khóa API"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/edtMoHinh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Mô hình, ví dụ: gemini-1.5-flash"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Nhắc lệnh hệ thống" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_item_ve"
            android:padding="4dp">

            <EditText
                android:id="@+id/edtNhacLenh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:hint="Nhập nhắc lệnh cho trợ lý AI"
                android:inputType="textMultiLine"
                android:minLines="5" />
        </ScrollView>

        <Button
            android:id="@+id/btnLuu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Lưu cấu hình" />

        <Button
            android:id="@+id/btnKiemTra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Kiểm tra AI" />

        <ProgressBar
            android:id="@+id/pgbDangTai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
