<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/lblTieuDe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_admin"
            android:elevation="@dimen/elevation_lg"
            android:padding="@dimen/space_xxl"
            android:text="🤖 Cấu hình AI Gemini"
            style="@style/App.Text.OnGradient.DisplaySm" />

        <EditText
            android:id="@+id/edtNhaCungCap"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:hint="URL endpoint Gemini"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/edtKhoaApi"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:hint="Khóa API"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/edtMoHinh"
            style="@style/App.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:hint="Mô hình, ví dụ: gemini-1.5-flash"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Nhắc lệnh hệ thống"
            style="@style/App.Text.SectionTitle" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_card_modern"
            android:elevation="@dimen/elevation_sm"
            android:padding="@dimen/space_sm">

            <EditText
                android:id="@+id/edtNhacLenh"
                style="@style/App.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="Nhập nhắc lệnh cho trợ lý AI"
                android:inputType="textMultiLine"
                android:minLines="5" />
        </ScrollView>

        <Button
            android:id="@+id/btnLuu"
            style="@style/App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/space_xl"
            android:text="💾 Lưu cấu hình" />

        <Button
            android:id="@+id/btnKiemTra"
            style="@style/App.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/space_sm"
            android:text="🧪 Kiểm tra AI" />

        <ProgressBar
            android:id="@+id/pgbDangTai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_md"
            android:indeterminateTint="@color/mauTimChinh"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
