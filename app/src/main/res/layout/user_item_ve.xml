<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_sm"
    android:layout_marginTop="@dimen/space_sm"
    android:layout_marginEnd="@dimen/space_sm"
    android:layout_marginBottom="@dimen/space_sm"
    android:background="@drawable/bg_card_modern"
    android:elevation="@dimen/elevation_md"
    android:foreground="@drawable/bg_ripple_bounded"
    android:orientation="vertical"
    android:padding="@dimen/space_md">

    <!-- ═══ Ảnh vé bo góc ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/img_card_height">

        <ImageView
            android:id="@+id/imgAnhVe"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Ảnh vé"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher" />

        <!-- ═══ Badge trạng thái ═══ -->
        <TextView
            style="@style/App.Badge.Success"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="@dimen/space_md"
            android:text="Đang mở bán" />
    </FrameLayout>

    <!-- ═══ Tên vé ═══ -->
    <TextView
        android:id="@+id/lblTenVe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Tên vé"
        style="@style/App.Text.Title" />

    <!-- ═══ Giá + nút ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/lblGiaVe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 VNĐ"
            style="@style/App.Text.Price" />

        <Button
            android:id="@+id/btnXem"
            style="@style/App.Button.Small"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/btn_height_sm"
            android:drawableEnd="@drawable/ic_mui_ten_phai"
            android:drawablePadding="@dimen/space_xs"
            android:drawableTint="@color/white"
            android:text="Xem ngay" />
    </LinearLayout>
</LinearLayout>
