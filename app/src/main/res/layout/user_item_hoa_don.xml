<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_item_ve"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/lblMaHoaDon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã hóa đơn:"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lblNgayLap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ngày lập:" />

    <TextView
        android:id="@+id/lblTongTien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tổng tiền: 0 VNĐ" />

    <TextView
        android:id="@+id/lblTrangThai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Trạng thái:" />

    <Button
        android:id="@+id/btnXemChiTiet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Xem chi tiết" />
</LinearLayout>
