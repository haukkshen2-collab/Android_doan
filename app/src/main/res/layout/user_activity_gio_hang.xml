<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical">

    <!-- ═══ Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginEnd="@dimen/space_lg"
        android:background="@drawable/bg_hero_user"
        android:elevation="@dimen/elevation_lg"
        android:orientation="vertical"
        android:padding="@dimen/space_xl">

        <TextView
            android:id="@+id/lblTieuDe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛒 Giỏ hàng"
            style="@style/App.Text.OnGradient.DisplaySm" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="Kiểm tra vé trước khi thanh toán"
            style="@style/App.Text.OnGradient.Body" />
    </LinearLayout>

    <!-- ═══ Empty state ═══ -->
    <TextView
        android:id="@+id/lblTrong"
        style="@style/App.EmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_xxl"
        android:layout_marginEnd="@dimen/space_lg"
        android:background="@drawable/bg_card_modern"
        android:text="🛒 Giỏ hàng đang trống\nHãy thêm vé để bắt đầu!"
        android:visibility="gone" />

    <!-- ═══ Danh sách ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvDanhSachGioHang"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm"
        android:paddingBottom="@dimen/space_sm" />

    <!-- ═══ Bottom sticky bar ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_modern"
        android:elevation="@dimen/elevation_xl"
        android:orientation="vertical"
        android:padding="@dimen/card_padding_lg">

        <TextView
            android:id="@+id/lblTongTien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tổng tiền: 0 VNĐ"
            style="@style/App.Text.PriceLg" />

        <Button
            android:id="@+id/btnThanhToan"
            style="@style/App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/space_md"
            android:text="💳 Thanh toán" />

        <Button
            android:id="@+id/btnTiepTucMua"
            style="@style/App.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/space_sm"
            android:text="Tiếp tục mua" />
    </LinearLayout>
</LinearLayout>
