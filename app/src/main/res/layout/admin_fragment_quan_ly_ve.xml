<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:id="@+id/lblTieuDe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎫 Quản lý vé"
        style="@style/App.Text.HeadingLg" />

    <EditText
        android:id="@+id/edtTimKiem"
        style="@style/App.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:hint="🔍 Tìm theo tên vé"
        android:inputType="text" />

    <Spinner
        android:id="@+id/spnLocLoaiVe"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@drawable/bg_card_modern"
        android:padding="@dimen/space_sm" />

    <Button
        android:id="@+id/btnThemVe"
        style="@style/App.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginTop="@dimen/space_sm"
        android:text="➕ Thêm vé" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvDanhSachVe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_weight="1"
        android:clipToPadding="false" />
</LinearLayout>
