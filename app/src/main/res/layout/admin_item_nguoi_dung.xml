<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_item_ve"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/lblTaiKhoan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tài khoản"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lblHoTen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Họ tên" />

    <TextView
        android:id="@+id/lblVaiTro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Vai trò" />

    <TextView
        android:id="@+id/lblTrangThai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Trạng thái" />

    <Switch
        android:id="@+id/swtKhoa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Khóa tài khoản" />

    <Button
        android:id="@+id/btnResetMatKhau"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Đặt lại mật khẩu" />
</LinearLayout>
