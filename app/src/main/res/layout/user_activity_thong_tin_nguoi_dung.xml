<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ Avatar section với gradient ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_user"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_xxl"
            android:paddingTop="@dimen/space_xxxl"
            android:paddingEnd="@dimen/space_xxl"
            android:paddingBottom="@dimen/space_xxxl">

            <ImageView
                android:layout_width="@dimen/avatar_size_lg"
                android:layout_height="@dimen/avatar_size_lg"
                android:background="@drawable/bg_logo_tron"
                android:contentDescription="Avatar"
                android:padding="@dimen/space_lg"
                android:src="@drawable/img_vaa_e1744105217584" />

            <TextView
                android:id="@+id/lblTieuDe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="Hồ sơ cá nhân"
                style="@style/App.Text.OnGradient.DisplaySm" />
        </LinearLayout>

        <!-- ═══ Thông tin ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="-20dp"
            android:layout_marginEnd="@dimen/space_lg"
            android:background="@drawable/bg_card_modern"
            android:elevation="@dimen/elevation_lg"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_lg">

            <TextView
                android:id="@+id/lblTaiKhoan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tài khoản:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblHoTen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Họ tên:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblSoDienThoai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Số điện thoại:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblVaiTro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vai trò:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblNgayDangKy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ngày đăng ký:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblTrangThai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trạng thái:"
                style="@style/App.Text.Body" />
        </LinearLayout>

        <!-- ═══ Buttons ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_xl"
            android:layout_marginEnd="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_xxl"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnCapNhat"
                style="@style/App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="Cập nhật thông tin" />

            <Button
                android:id="@+id/btnDoiMatKhau"
                android:drawableStart="@drawable/ic_khoa"
                android:drawablePadding="@dimen/space_xs"
                android:drawableTint="@color/mauTimChinh"
                style="@style/App.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Đổi mật khẩu" />

            <Button
                android:id="@+id/btnDangXuat"
                android:drawableStart="@drawable/ic_dang_xuat"
                android:drawablePadding="@dimen/space_xs"
                android:drawableTint="@color/mauNguyHiem"
                style="@style/App.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Đăng xuất" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
