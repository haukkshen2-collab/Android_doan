<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/lblTieuDe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Chi tiết hóa đơn"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblMaHoaDon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Mã hóa đơn:" />

        <TextView
            android:id="@+id/lblNgayLap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ngày lập:" />

        <TextView
            android:id="@+id/lblTongTien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tổng tiền: 0 VNĐ" />

        <TextView
            android:id="@+id/lblTienGiam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tiền giảm: 0 VNĐ" />

        <TextView
            android:id="@+id/lblThanhTien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Thành tiền: 0 VNĐ"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblHinhThuc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hình thức thanh toán:" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvChiTietHoaDon"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnDong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Đóng" />
    </LinearLayout>
</ScrollView>
