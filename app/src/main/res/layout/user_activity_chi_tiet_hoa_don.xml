<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- ═══ Header ═══ -->
        <TextView
            android:id="@+id/lblTieuDe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_user"
            android:elevation="@dimen/elevation_lg"
            android:gravity="center_vertical"
            android:padding="@dimen/space_xxl"
            android:text="🧾 Chi tiết hóa đơn"
            style="@style/App.Text.OnGradient.DisplaySm" />

        <!-- ═══ Thông tin hóa đơn ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_card_modern"
            android:elevation="@dimen/elevation_md"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_lg">

            <TextView
                android:id="@+id/lblMaHoaDon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mã hóa đơn:"
                style="@style/App.Text.Body" />

            <TextView
                android:id="@+id/lblNgayLap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Ngày lập:"
                style="@style/App.Text.Body" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_divider" />

            <TextView
                android:id="@+id/lblTongTien"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tổng tiền: 0 VNĐ"
                style="@style/App.Text.Body" />

            <TextView
                android:id="@+id/lblTienGiam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Tiền giảm: 0 VNĐ"
                android:textColor="@color/mauThanhCong"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/lblThanhTien"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_price_badge"
                android:padding="@dimen/space_md"
                android:text="Thành tiền: 0 VNĐ"
                style="@style/App.Text.PriceLg" />

            <TextView
                android:id="@+id/lblHinhThuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="Hình thức thanh toán:"
                style="@style/App.Text.BodySm" />
        </LinearLayout>

        <!-- ═══ Chi tiết vé ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:text="Chi tiết vé"
            style="@style/App.Text.SectionTitle" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvChiTietHoaDon"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="@dimen/space_sm" />

        <Button
            android:id="@+id/btnDong"
            style="@style/App.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_xxl"
            android:text="Đóng" />
    </LinearLayout>
</ScrollView>
