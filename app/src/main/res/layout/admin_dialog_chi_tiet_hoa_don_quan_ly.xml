<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/lblMaHoaDon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã hóa đơn"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lblHoTenKhach"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Khách hàng" />

    <TextView
        android:id="@+id/lblNgayLap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ngày lập" />

    <TextView
        android:id="@+id/lblTongTien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tổng tiền" />

    <TextView
        android:id="@+id/lblTienGiam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tiền giảm" />

    <TextView
        android:id="@+id/lblPhaiTra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Phải trả" />

    <TextView
        android:id="@+id/lblHinhThuc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Hình thức thanh toán" />

    <TextView
        android:id="@+id/lblTrangThai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Trạng thái" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvChiTietHoaDon"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnDong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Đóng" />
</LinearLayout>
