<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgAnhVe"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:contentDescription="Ảnh vé"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/lblTenVe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tên vé"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblMoTa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mô tả" />

        <TextView
            android:id="@+id/lblThongTinVe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Thông tin vé" />

        <TextView
            android:id="@+id/lblGiaNguoiLon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Người lớn: 0 VNĐ" />

        <TextView
            android:id="@+id/lblGiaTreEm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Trẻ em: 0 VNĐ" />

        <TextView
            android:id="@+id/lblGiaCaoTuoi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Người cao tuổi: 0 VNĐ" />

        <Button
            android:id="@+id/btnChonVe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Chọn vé" />
    </LinearLayout>
</ScrollView>
