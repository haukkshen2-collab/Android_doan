<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_man_hinh"
    android:orientation="vertical">

    <!-- ═══ Header chào người dùng ═══ -->
    <LinearLayout
        android:id="@+id/layHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_user"
        android:elevation="@dimen/elevation_lg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:paddingTop="@dimen/space_md"
        android:paddingBottom="@dimen/space_md">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_logo_tron"
            android:contentDescription="Logo khu du lịch"
            android:padding="@dimen/space_sm"
            android:src="@drawable/img_vaa_e1744105217584" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chào mừng trở lại"
                style="@style/App.Text.OnGradient.Body"
                android:textSize="@dimen/text_small" />

            <TextView
                android:id="@+id/lblXinChao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Xin chào"
                style="@style/App.Text.OnGradient.Subtitle" />
        </LinearLayout>

        <Button
            android:id="@+id/btnHoSo"
            style="@style/App.Button.OnGradient"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="@dimen/space_xs"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:drawableStart="@drawable/ic_ho_so"
            android:drawablePadding="@dimen/space_xs"
            android:drawableTint="@color/mauTimDam"
            android:text="Hồ sơ"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/btnDangXuat"
            style="@style/App.IconButton.OnGradient"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="Đăng xuất"
            android:padding="@dimen/space_sm"
            android:src="@drawable/ic_dang_xuat" />
    </LinearLayout>

    <!-- ═══ Danh mục vé ═══ -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginEnd="@dimen/space_lg"
        android:text="Danh mục vé"
        style="@style/App.Text.SectionTitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvLoaiVe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:clipToPadding="false"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm" />

    <!-- ═══ Vé nổi bật ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginEnd="@dimen/space_lg"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/icon_sm"
            android:layout_height="@dimen/icon_sm"
            android:contentDescription="Vé nổi bật"
            android:src="@drawable/ic_ve"
            android:tint="@color/mauTimChinh" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xs"
            android:text="Vé nổi bật"
            style="@style/App.Text.SectionTitle" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvDanhSachVe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_xs"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/space_xs"
        android:paddingEnd="@dimen/space_xs"
        android:paddingBottom="@dimen/space_sm" />

    <!-- ═══ Bottom navigation ═══ -->
    <LinearLayout
        android:id="@+id/layBottomMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_thanh_menu"
        android:elevation="@dimen/elevation_xl"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_sm">

        <LinearLayout
            android:id="@+id/btnTrangChu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:contentDescription="Trang chủ"
                android:src="@drawable/ic_trang_chu"
                android:tint="@color/mauTimChinh" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Trang chủ"
                android:textColor="@color/mauTimChinh"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnGioHang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:contentDescription="Giỏ hàng"
                android:src="@drawable/ic_gio_hang"
                android:tint="@color/mauChuMo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Giỏ hàng"
                android:textColor="@color/mauChuPhu"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnLichSu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:contentDescription="Lịch sử đơn hàng"
                android:src="@drawable/ic_lich_su"
                android:tint="@color/mauChuMo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Lịch sử"
                android:textColor="@color/mauChuPhu"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnChatAI"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:contentDescription="Trợ lý ảo"
                android:src="@drawable/ic_chat"
                android:tint="@color/mauChuMo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Trợ lý"
                android:textColor="@color/mauChuPhu"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
