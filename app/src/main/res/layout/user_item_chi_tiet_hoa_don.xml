<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_item_ve"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/lblTenVe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên vé"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lblNgaySuDung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ngày sử dụng:" />

    <TextView
        android:id="@+id/lblSoLuong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="NL: 0 | TE: 0 | CT: 0" />

    <TextView
        android:id="@+id/lblDonGia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Đơn giá:" />

    <TextView
        android:id="@+id/lblThanhTien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Thành tiền: 0 VNĐ"
        android:textStyle="bold" />
</LinearLayout>
